{
  "name": "adhicode-studio",
  "version": "2.0.0",
  "description": "ADHICODE Studio - AI-Powered Development Platform with Terminal, Tools & Workflows",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "bun build --compile --target=bun-windows-x64 --minify --sourcemap ./src/index.ts --outfile=ADHICODE-Studio",
    "build:linux": "bun build --compile --target=bun-linux-x64 --minify --sourcemap ./src/index.ts --outfile=ADHICODE-Studio",
    "dev": "bun run ./src/index.ts",
    "jarvis": "bun run ./src/index.ts jarvis",
    "terminal": "bun run ./src/index.ts terminal"
  },
  "bin": {
    "adhicode-studio": "bin/launcher.js"
  },
  "dependencies": {
    "yargs": "18.0.0",
    "zod": "^3.24.0",
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
